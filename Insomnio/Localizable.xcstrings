    "app_description" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keeps your Mac awake by simulating activity. Choose a mode and interval shorter than your screensaver or display sleep settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantiene tu Mac despierta simulando actividad. Elige un modo e intervalo menor al tiempo de protector de pantalla o suspensión de pantalla."
          }
        }
      }
    },
